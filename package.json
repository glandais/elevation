{
    "name": "@glandais/elevation",
    "version": "3.1.4",
    "description": "TypeScript library for retrieving elevation data from geographic coordinates using terrain RGB tiles",
    "sideEffects": false,
    "main": "./dist/index.umd.js",
    "module": "./dist/index.esm.js",
    "types": "./dist/index.d.ts",
    "browser": "./dist/index.esm.js",
    "jsdelivr": "./dist/index.esm.js",
    "unpkg": "./dist/index.esm.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "browser": "./dist/index.esm.js",
            "node": {
                "import": "./dist/index.node.mjs",
                "require": "./dist/index.node.js"
            },
            "import": "./dist/index.esm.js",
            "require": "./dist/index.umd.js",
            "default": "./dist/index.esm.js"
        }
    },
    "files": [
        "dist/",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "dev": "npm run build:dev && npm run dev:serve",
        "dev:watch": "vite build --watch --mode info",
        "dev:serve": "serve . -l 3000",
        "build": "npm run build:clean && npm run build:browser && npm run build:node && npm run build:combine",
        "build:clean": "rm -rf dist",
        "build:browser": "BUILD_TARGET=browser vite build",
        "build:node": "BUILD_TARGET=node vite build",
        "build:combine": "cp dist/browser/* dist/ && cp dist/node/index.node.* dist/ && rm -rf dist/browser dist/node",
        "build:dev": "vite build --mode development",
        "check": "npm run format && npm run lint:fix && npm run lint && npm run typecheck && npm run test:all && npm run build",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:all": "npm run test && npm run test:browser",
        "test:browser": "npm run build:dev && playwright test",
        "test:browser:ui": "npm run build:dev && playwright test --ui",
        "test:browser:headed": "npm run build:dev && playwright test --headed",
        "lint": "eslint src/ test/ --ext .ts",
        "lint:fix": "eslint src/ test/ --ext .ts --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "semantic-release": "semantic-release",
        "prepare": "husky",
        "prepublishOnly": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/glandais/elevation.git"
    },
    "keywords": [
        "elevation",
        "terrain",
        "geographic",
        "coordinates",
        "gis",
        "typescript",
        "tiles",
        "srtm"
    ],
    "author": "glandais",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/glandais/elevation/issues"
    },
    "homepage": "https://github.com/glandais/elevation#readme",
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "access": "public"
    },
    "lint-staged": {
        "*.{ts,js}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^20.0.0",
        "@commitlint/config-conventional": "^20.0.0",
        "@eslint/js": "^9.34.0",
        "@playwright/test": "^1.55.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/exec": "^7.1.0",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.0",
        "@semantic-release/npm": "^13.1.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.0.3",
        "@typescript-eslint/eslint-plugin": "^8.41.0",
        "@typescript-eslint/parser": "^8.41.0",
        "@vitest/coverage-v8": "^4.0.3",
        "eslint": "^9.34.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "husky": "^9.1.7",
        "jest": "^30.0.5",
        "jest-environment-jsdom": "^30.0.5",
        "lint-staged": "^16.1.5",
        "playwright": "^1.55.0",
        "prettier": "^3.6.2",
        "semantic-release": "^25.0.1",
        "semantic-release-plugin-update-version-in-files": "^2.0.0",
        "serve": "^14.2.4",
        "ts-jest": "^29.4.1",
        "typescript": "^5.9.2",
        "vite": "^7.1.3",
        "vite-plugin-dts": "^4.5.4"
    },
    "dependencies": {
        "abort-controller": "^3.0.0",
        "canvas": "^3.2.0",
        "node-fetch": "^3.3.2"
    }
}
